# HR Agent 后端环境配置

# 应用设置
PROJECT_NAME=HR Agent
VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000
API_V1_STR=/api/v1

# 安全配置
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 数据库配置
DATABASE_URL=postgresql://hr_agent_user:hr_agent_password@10.58.8.46:5432/hr_agent
DATABASE_HOST=10.58.8.46
DATABASE_PORT=5432
DATABASE_USER=hr_agent_user
DATABASE_PASSWORD=hr_agent_password
DATABASE_NAME=hr_agent


# 远程服务配置
HR_SERVICE_HOST=121.43.198.13
HR_SERVICE_PORT=8000
HR_SERVICE_APIKEY=9603dda8815345f2b09c8f8ec4f58187

# CORS 设置
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:5173"]


# LLM 设置
LLM_API_KEY=sk-6dd377eebad84cbeb1a95f0a9ba365ea
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-max

# Qwen 重排序设置
QWEN_API_KEY=sk-8709f7ed33dc402a8a9885a1a8ee403e
QWEN_MODEL=gte-rerank-v2

# 嵌入设置
EMBEDDING_API_KEY=sk-8709f7ed33dc402a8a9885a1a8ee403e
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v1

# 查询改写设置
KB_QUERY_ENHANCE_ENABLED=true
  # 启用查询改写功能
KB_QUERY_EXPANSION_MAX_TERMS=6
  # 查询扩展最大术语数量

# 向量数据库（pgvector）
VECTOR_DIMENSION=1536


# 文件上传设置
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=["pdf","docx","txt","md"]
UPLOAD_DIR=uploads

# 日志配置
LOG_LEVEL=INFO

# 远程服务请求/响应日志配置
REMOTE_SERVICE_LOG_ENABLED=false 
 # 是否输出远程服务请求/响应详情

# 上下文配置
CONTEXT_LIMIT=5

# Dify 工作流配置
DIFY_BASE_URL=http://10.58.8.46/v1
DIFY_API_KEY=app-7quxCCaxMMaTQqTwGBxuy0Sn
DIFY_USER_ID=hr-agent-user

# 重排序设置
RERANK_ENABLED=true
RERANK_TOP_K=10
RERANK_FINAL_K=10

# RAG 分数组合权重设置
RAG_CONTENT_WEIGHT=0.7
  # 向量相似度权重
RAG_TEXT_WEIGHT=0.3
  # 文本匹配权重